# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
build/
dist/

# --- Virtualenvs ---
.venv/
venv/
env/

# --- Local outputs / logs ---
wandb/
runs/
logs/
outputs/
multirun/
*.log
checkpoints/

# --- Bundled archives ---
cppo.zip
*.tar.gz
*.zip

# --- Mava: ignore the vendored tree at the top level, EXCEPT our jaxgcrl port.
# Use `mava/*` (not `mava/`) so git still descends and the !rules below apply. ---
mava/*
!mava/jaxgcrl/
!mava/configs/
# mava/configs/ exists but only the jaxgcrl subdir is ours.
mava/configs/*
!mava/configs/jaxgcrl/
cppo-code/

# --- Dev artefacts that snuck into the work area ---
example.py
Screenshot*.png

# --- Secrets / local config ---
.env
.env.*
!.env.example

# --- IDE / OS ---
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# --- JAX cache ---
.jax_cache/
